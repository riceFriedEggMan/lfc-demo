<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.rice.msg.mapper.TMsgRecordMapper">
    <resultMap id="msgRecordMap" type="com.rice.msg.entity.TMsgRecord">
        <result column="id" property="id" />
        <result column="msg_id" property="msgId"/>
        <result column="to"  property="to"/>
        <result column="subject"  property="subject"/>
        <result column="channel"  property="channel"/>
        <result column="source_id"  property="sourceId"/>
        <result column="template_id"  property="templateId"/>
        <result column="template_data"  property="templateData"/>
        <result column="status"  property="status"/>
        <result column="retry_count"  property="retryCount"/>
    </resultMap>


    <insert id="save" useGeneratedKeys="true" keyProperty="id">
        insert into t_msg_record (`msg_id`,`to`,`subject`,`source_id`,`channel`,`template_id`,`template_data`,`status`,`retry_count`)
        values (#{msgId},#{to},#{subject},#{sourceId},#{channel},#{templateId},#{templateData},#{status},#{retryCount});
    </insert>
</mapper>